{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q 'git commit'; then bash scripts/validate-ts.sh; fi",
            "timeout": 60000,
            "blocking": true
          }
        ]
      }
    ]
  }
}
