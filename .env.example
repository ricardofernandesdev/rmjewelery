# ─────────────────────────────────────────────
# Local development (.env)
# ─────────────────────────────────────────────

# Postgres connection string
# Local: postgresql://postgres:postgres@localhost:5432/rmjewelery
# Vercel Postgres: copiado do dashboard Vercel → Storage → Postgres
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/rmjewelery

# Random secret used by Payload to encrypt cookies/tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-random-secret

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────
# Media storage — Cloudflare R2 (S3-compatible)
# Leave empty for local dev (uses ./media folder)
# ─────────────────────────────────────────────
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
