# ─────────────────────────────────────────────
# Local development (.env)
# ─────────────────────────────────────────────

# Postgres connection string
# Local: postgresql://postgres:postgres@localhost:5432/rmjewelery
# Production (Neon): postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/rmjewelery

# Random secret used by Payload to encrypt cookies/tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-random-secret

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Instagram username (frontend)
NEXT_PUBLIC_INSTAGRAM_USERNAME=rmjewelery

NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────
# Production-only — Cloudflare R2 (S3-compatible) media storage
# Leave empty for local dev (uses ./media folder)
# ─────────────────────────────────────────────

# R2 bucket name
S3_BUCKET=

# R2 endpoint, format: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=

# R2 region (always "auto" for Cloudflare)
S3_REGION=auto

# R2 API token credentials (create in Cloudflare dashboard → R2 → Manage API Tokens)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
